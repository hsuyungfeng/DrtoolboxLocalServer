{
  "chroma": {
    "type": "persistant",
    "path": "data/rag/chroma/",
    "collections": {
      "general_medical": "general_medical",
      "clinic_specific": "clinic_specific"
    },
    "default_collection": "general_medical"
  },
  "document_folders": {
    "general_medical": "data/rag/general_docs/",
    "clinic_specific": "data/rag/clinic_docs/"
  },
  "chunking": {
    "chunk_size": 512,
    "chunk_overlap": 50,
    "min_chunk_size": 100,
    "max_chunk_size": 1024
  },
  "embedding": {
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "device": "cpu",
    "batch_size": 32
  },
  "supported_formats": [
    ".txt",
    ".pdf",
    ".docx",
    ".json"
  ],
  "ingestion": {
    "max_file_size_mb": 50,
    "timeout_seconds": 120,
    "skip_large_files": true
  },
  "search": {
    "default_n_results": 5,
    "max_n_results": 20,
    "min_relevance_score": 0.3
  },
  "metadata": {
    "track_source": true,
    "track_page": true,
    "track_section": true,
    "track_ingestion_time": true
  }
}